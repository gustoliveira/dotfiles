{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-gemini-auth@latest"],
  "permission": {
    "read": {
      "*.env": "ask",       
      "*.env.*": "ask",
      "*.env.example": "allow",
      "*.secret": "ask",
      "*.veil": "ask",
      "*": "allow"
    },
    "edit": {
      "*": "ask"
    },
    "bash": {
      "*": "ask",
      "git *": "ask",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "docker ps": "allow",
      "docker ps *": "allow",
      "docker compose logs": "allow",
      "docker compose logs *": "allow"
    },
    "list": {
      "*": "allow"
    }
  }
}
